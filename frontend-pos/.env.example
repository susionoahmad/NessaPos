# Pilih koneksi API untuk frontend-pos dan build Wails.
# local  = pakai Laravel lokal
# online = pakai Laravel production
VITE_API_MODE=local

# URL Laravel lokal.
VITE_API_URL_LOCAL=http://localhost:8000/api

# URL Laravel online. Boleh tanpa /api, aplikasi akan menambahkan /api otomatis.
VITE_API_URL_ONLINE=https://nessapos.kalkulatorin.com

# Kompatibilitas lama: jika VITE_API_MODE kosong, VITE_API_URL tetap dipakai.
VITE_API_URL=http://localhost:8000/api
