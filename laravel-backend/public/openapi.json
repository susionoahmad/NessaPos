{
  "openapi": "3.0.3",
  "info": {
    "title": "NessaPOS API",
    "description": "OpenAPI definition for the NessaPOS Laravel backend.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.domain.com/api"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "LoginRequest": {
        "type": "object",
        "properties": {
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string" }
        },
        "required": ["email", "password"]
      },
      "RegisterRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string" }
        },
        "required": ["name", "email", "password"]
      },
      "OrderRequest": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "product_id": { "type": "integer" },
                "quantity": { "type": "integer" }
              },
              "required": ["product_id", "quantity"]
            }
          },
          "payment_method": { "type": "string" },
          "total": { "type": "number" }
        },
        "required": ["items", "payment_method", "total"]
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/login": {
      "post": {
        "summary": "User login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LoginRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Successful login" }
        }
      }
    },
    "/register": {
      "post": {
        "summary": "Register new account",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RegisterRequest" }
            }
          }
        },
        "responses": {
          "201": { "description": "User created" }
        }
      }
    },
    "/packages": {
      "get": {
        "summary": "List subscription packages",
        "responses": {
          "200": { "description": "List of packages" }
        }
      }
    },
    "/logout": {
      "post": {
        "summary": "Logout current user",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Logged out" }
        }
      }
    },
    "/settings/subscription": {
      "put": {
        "summary": "Update tenant subscription settings",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Subscription updated" }
        }
      }
    },
    "/settings/setup": {
      "post": {
        "summary": "Complete application setup",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Setup complete" }
        }
      }
    },
    "/subscription/renew": {
      "post": {
        "summary": "Create subscription renewal request",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "201": { "description": "Renewal request created" }
        }
      }
    },
    "/tenant/info": {
      "get": {
        "summary": "Get current tenant info",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Tenant information" }
        }
      }
    },
    "/products": {
      "get": {
        "summary": "List products",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Products list" }
        }
      },
      "post": {
        "summary": "Create a product",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "201": { "description": "Product created" }
        }
      }
    },
    "/products/{product}": {
      "put": {
        "summary": "Update a product",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "product", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Product updated" }
        }
      },
      "delete": {
        "summary": "Delete a product",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "product", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "204": { "description": "Product deleted" }
        }
      }
    },
    "/stock-mutations": {
      "get": {
        "summary": "List stock mutation history",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Stock mutations list" }
        }
      }
    },
    "/orders": {
      "get": {
        "summary": "List orders",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Orders list" }
        }
      },
      "post": {
        "summary": "Create an order",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/OrderRequest" }
            }
          }
        },
        "responses": {
          "201": { "description": "Order created" }
        }
      }
    },
    "/orders/stats": {
      "get": {
        "summary": "Get daily order statistics",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Order statistics" }
        }
      }
    },
    "/sessions": {
      "get": {
        "summary": "List cashier sessions",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Sessions list" }
        }
      }
    },
    "/sessions/current": {
      "get": {
        "summary": "Get current session",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Current session details" }
        }
      }
    },
    "/sessions/open": {
      "post": {
        "summary": "Open a cashier session",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "201": { "description": "Session opened" }
        }
      }
    },
    "/sessions/close": {
      "post": {
        "summary": "Close the current cashier session",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Session closed" }
        }
      }
    },
    "/cashier-transactions": {
      "get": {
        "summary": "Get cashier transaction history",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Cashier transactions" }
        }
      }
    },
    "/vault": {
      "get": {
        "summary": "Get vault information",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Vault info" }
        }
      }
    },
    "/vault/transactions": {
      "get": {
        "summary": "List vault transactions",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Vault transactions" }
        }
      }
    },
    "/vault/deposit": {
      "post": {
        "summary": "Create a vault deposit transaction",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "201": { "description": "Vault deposit created" }
        }
      }
    },
    "/settings": {
      "get": {
        "summary": "Get current settings",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Settings data" }
        }
      },
      "put": {
        "summary": "Update settings",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Settings updated" }
        }
      }
    },
    "/users": {
      "get": {
        "summary": "List users",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Users list" }
        }
      },
      "post": {
        "summary": "Create a user",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "201": { "description": "User created" }
        }
      }
    },
    "/users/{id}": {
      "put": {
        "summary": "Update a user",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "User updated" }
        }
      },
      "delete": {
        "summary": "Delete a user",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "204": { "description": "User deleted" }
        }
      }
    },
    "/superadmin/stats": {
      "get": {
        "summary": "Get admin statistics",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Statistics" }
        }
      }
    },
    "/superadmin/tenants": {
      "get": {
        "summary": "List tenants",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Tenants list" }
        }
      },
      "post": {
        "summary": "Create a tenant",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "201": { "description": "Tenant created" }
        }
      }
    },
    "/superadmin/tenants/{id}/subscription": {
      "put": {
        "summary": "Update tenant subscription",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Subscription updated" }
        }
      }
    },
    "/superadmin/tenants/{id}/toggle": {
      "post": {
        "summary": "Enable or disable a tenant",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Tenant toggled" }
        }
      }
    },
    "/superadmin/tenants/{id}": {
      "delete": {
        "summary": "Delete a tenant",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "204": { "description": "Tenant deleted" }
        }
      }
    },
    "/superadmin/packages": {
      "get": {
        "summary": "List subscription packages",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Packages list" }
        }
      }
    },
    "/superadmin/packages/{id}": {
      "put": {
        "summary": "Update subscription package",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Package updated" }
        }
      }
    },
    "/superadmin/renewals": {
      "get": {
        "summary": "List renewal requests",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Renewal requests" }
        }
      }
    },
    "/superadmin/renewals/{id}/approve": {
      "post": {
        "summary": "Approve a renewal request",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Renewal approved" }
        }
      }
    },
    "/superadmin/renewals/{id}/reject": {
      "post": {
        "summary": "Reject a renewal request",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Renewal rejected" }
        }
      }
    }
  }
}
